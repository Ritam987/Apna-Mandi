<!-- ── Bottom Navigation Bar ──────────────────────────────────── -->
<% if (typeof showNav === 'undefined' || showNav !== false) { %>

<nav class="apna-nav" role="navigation" aria-label="Main navigation">

  <!-- Decorative top border with animated gradient -->
  <div class="apna-nav__top-border"></div>

  <!-- Soft inner glow layer -->
  <div class="apna-nav__glow-bg"></div>

  <div class="apna-nav__inner">

    <!-- Home -->
    <a href="/pages/Homepage"
       class="apna-nav__item <%= typeof activePage !== 'undefined' && activePage === 'home' ? 'apna-nav__item--active' : '' %>"
       aria-label="Home">
      <div class="apna-nav__icon-wrap">
        <svg class="apna-nav__icon" viewBox="0 0 256 256" fill="currentColor">
          <path d="M224,115.55V208a16,16,0,0,1-16,16H168a16,16,0,0,1-16-16V168a8,8,0,0,0-8-8H112a8,8,0,0,0-8,8v40a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V115.55a16,16,0,0,1,5.17-11.78l80-75.48.11-.11a16,16,0,0,1,21.53,0,1.14,1.14,0,0,0,.11.11l80,75.48A16,16,0,0,1,224,115.55Z"/>
        </svg>
        <% if (typeof activePage !== 'undefined' && activePage === 'home') { %>
        <span class="apna-nav__active-pill"></span>
        <% } %>
      </div>
      <span class="apna-nav__label">Home</span>
    </a>

    <!-- Search -->
    <a href="/pages/searchfeed"
       class="apna-nav__item <%= typeof activePage !== 'undefined' && activePage === 'categories' ? 'apna-nav__item--active' : '' %>"
       aria-label="Search">
      <div class="apna-nav__icon-wrap">
        <svg class="apna-nav__icon" viewBox="0 0 256 256" fill="currentColor">
          <path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"/>
        </svg>
        <% if (typeof activePage !== 'undefined' && activePage === 'categories') { %>
        <span class="apna-nav__active-pill"></span>
        <% } %>
      </div>
      <span class="apna-nav__label">Search</span>
    </a>

    <!-- Cart — centre FAB -->
    <a href="/pages/hubcart"
       class="apna-nav__item apna-nav__item--fab <%= typeof activePage !== 'undefined' && activePage === 'cart' ? 'apna-nav__item--active' : '' %>"
       aria-label="Hub Cart">
      <div class="apna-nav__fab-wrap">
        <div class="apna-nav__fab-ring"></div>
        <div class="apna-nav__fab">
          <svg class="apna-nav__fab-icon" viewBox="0 0 256 256" fill="currentColor">
            <path d="M222.14,58.87A8,8,0,0,0,216,56H54.68L49.79,29.14A16,16,0,0,0,34.05,16H16a8,8,0,0,0,0,16h18L59.56,172.29a24,24,0,0,0,5.33,11.27,28,28,0,1,0,44.4,8.44h45.42A27.75,27.75,0,0,0,152,204a28,28,0,1,0,28-28H83.17a8,8,0,0,1-7.87-6.57L72.13,152h116a24,24,0,0,0,23.61-19.71l12.16-66.86A8,8,0,0,0,222.14,58.87ZM96,204a12,12,0,1,1-12-12A12,12,0,0,1,96,204Zm96,0a12,12,0,1,1-12-12A12,12,0,0,1,192,204Zm4-74.57A8,8,0,0,1,188.1,136H69.22L57.59,72H206.41Z"/>
          </svg>
          <span id="nav-cart-badge" class="apna-nav__fab-badge" style="display:none">0</span>
        </div>
      </div>
      <span class="apna-nav__label apna-nav__label--fab">Cart</span>
    </a>

    <!-- Offers -->
    <a href="/pages/specialoffers"
       class="apna-nav__item <%= typeof activePage !== 'undefined' && activePage === 'surplus' ? 'apna-nav__item--active' : '' %>"
       aria-label="Special Offers">
      <div class="apna-nav__icon-wrap">
        <svg class="apna-nav__icon" viewBox="0 0 256 256" fill="currentColor">
          <path d="M152,120H136V56h8a32,32,0,0,1,32,32,8,8,0,0,0,16,0,48.05,48.05,0,0,0-48-48h-8V24a8,8,0,0,0-16,0V40h-8a48,48,0,0,0,0,96h8v64H104a32,32,0,0,1-32-32,8,8,0,0,0-16,0,48.05,48.05,0,0,0,48,48h16v16a8,8,0,0,0,16,0V216h16a48,48,0,0,0,0-96Zm-40,0a32,32,0,0,1,0-64h8v64Zm40,80H136V136h16a32,32,0,0,1,0,64Z"/>
        </svg>
        <% if (typeof activePage !== 'undefined' && activePage === 'surplus') { %>
        <span class="apna-nav__active-pill"></span>
        <% } %>
      </div>
      <span class="apna-nav__label">Offers</span>
    </a>

    <!-- Profile -->
    <a href="/pages/account"
       class="apna-nav__item <%= typeof activePage !== 'undefined' && activePage === 'profile' ? 'apna-nav__item--active' : '' %>"
       aria-label="Profile">
      <div class="apna-nav__icon-wrap">
        <svg class="apna-nav__icon" viewBox="0 0 256 256" fill="currentColor">
          <path d="M230.92,212c-15.23-26.33-38.7-45.21-66.09-54.16a72,72,0,1,0-73.66,0C63.78,166.78,40.31,185.66,25.08,212a8,8,0,1,0,13.85,8c18.84-32.56,52.14-52,89.07-52s70.23,19.44,89.07,52a8,8,0,1,0,13.85-8ZM72,96a56,56,0,1,1,56,56A56.06,56.06,0,0,1,72,96Z"/>
        </svg>
        <% if (typeof activePage !== 'undefined' && activePage === 'profile') { %>
        <span class="apna-nav__active-pill"></span>
        <% } %>
      </div>
      <span class="apna-nav__label">Profile</span>
    </a>

  </div>
</nav>

<style>
/* ═══════════════════════════════════════════════════════════
   APNA MANDI — Premium Bottom Navigation Bar
   ═══════════════════════════════════════════════════════════ */

/* ── Outer shell ── */
.apna-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  z-index: 200;

  /* Layered glass morphism */
  background: linear-gradient(
    180deg,
    rgba(255, 248, 255, 0.97) 0%,
    rgba(255, 240, 250, 0.99) 100%
  );
  backdrop-filter: blur(28px) saturate(180%);
  -webkit-backdrop-filter: blur(28px) saturate(180%);

  /* Rounded top corners */
  border-radius: 22px 22px 0 0;

  /* Rich shadow stack */
  box-shadow:
    0 -1px 0   rgba(138, 43, 226, 0.08),
    0 -4px 16px rgba(138, 43, 226, 0.14),
    0 -12px 40px rgba(107, 31, 181, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.9);

  /* Safe area for notched phones */
  padding-bottom: env(safe-area-inset-bottom, 0px);
}

/* ── Animated gradient top border ── */
.apna-nav__top-border {
  height: 3px;
  border-radius: 22px 22px 0 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    #c77dff 15%,
    #8A2BE2 35%,
    #4B0082 50%,
    #8A2BE2 65%,
    #c77dff 85%,
    transparent 100%
  );
  background-size: 200% 100%;
  animation: border-shimmer 4s linear infinite;
}
@keyframes border-shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ── Soft inner glow ── */
.apna-nav__glow-bg {
  position: absolute;
  top: 3px; left: 10%; right: 10%;
  height: 36px;
  background: radial-gradient(ellipse at 50% 0%, rgba(138,43,226,0.10) 0%, transparent 70%);
  pointer-events: none;
}

/* ── Inner flex row — constrained width, centred ── */
.apna-nav__inner {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  /* Full width on desktop, constrained on mobile */
  max-width: 100%;
  margin: 0 auto;
  padding: 0.5rem 1rem 0.6rem;
  gap: 0;
  position: relative;
  /* Reserve vertical space so FAB doesn't overflow the nav height */
  min-height: 4rem;
}

@media (min-width: 768px) {
  .apna-nav__inner {
    max-width: 640px;
  }
}

@media (min-width: 1024px) {
  .apna-nav__inner {
    max-width: 100%;
    padding: 0.5rem 3rem 0.6rem;
  }
}

/* ══════════════════════════════════════
   NAV ITEM (non-FAB)
   ══════════════════════════════════════ */
.apna-nav__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 0.2rem;
  flex: 1;
  min-width: 0;           /* prevent flex children from overflowing */
  padding: 0.4rem 0.25rem 0.2rem;
  border-radius: 16px;
  color: #b0b0c8;
  text-decoration: none;
  transition:
    color 0.22s cubic-bezier(0.4,0,0.2,1),
    background 0.22s cubic-bezier(0.4,0,0.2,1),
    transform 0.18s cubic-bezier(0.34,1.56,0.64,1);
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  position: relative;
}
.apna-nav__item:hover {
  color: #8A2BE2;
  background: rgba(138, 43, 226, 0.06);
}
.apna-nav__item:active {
  transform: scale(0.88);
}
.apna-nav__item--active {
  color: #8A2BE2;
}

/* ── Icon wrap ── */
.apna-nav__icon-wrap {
  position: relative;
  /* Use vw-based size so it scales with screen, clamped between 36px–44px */
  width: clamp(36px, 9vw, 44px);
  height: clamp(36px, 9vw, 44px);
  border-radius: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.22s ease, box-shadow 0.22s ease, transform 0.18s cubic-bezier(0.34,1.56,0.64,1);
  flex-shrink: 0;
}
.apna-nav__item--active .apna-nav__icon-wrap {
  background: linear-gradient(135deg, rgba(199,125,255,0.22) 0%, rgba(138,43,226,0.18) 100%);
  box-shadow: 0 2px 12px rgba(138, 43, 226, 0.22), inset 0 1px 0 rgba(255,255,255,0.6);
  transform: translateY(-2px);
}

.apna-nav__icon {
  /* Scale icon relative to its wrap */
  width: clamp(18px, 4.5vw, 22px);
  height: clamp(18px, 4.5vw, 22px);
  transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
  flex-shrink: 0;
}
.apna-nav__item--active .apna-nav__icon {
  transform: scale(1.12);
  filter: drop-shadow(0 0 4px rgba(138,43,226,0.5));
}

/* ── Active indicator pill ── */
.apna-nav__active-pill {
  position: absolute;
  bottom: -4px;
  left: 50%;
  transform: translateX(-50%);
  width: 16px;
  height: 3px;
  border-radius: 99px;
  background: linear-gradient(90deg, #c77dff, #8A2BE2);
  box-shadow: 0 0 6px rgba(138, 43, 226, 0.7);
  animation: pill-pop 0.35s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes pill-pop {
  from { transform: translateX(-50%) scaleX(0); opacity: 0; }
  to   { transform: translateX(-50%) scaleX(1); opacity: 1; }
}

/* ── Label ── */
.apna-nav__label {
  font-size: clamp(9px, 2.2vw, 11px);
  font-weight: 600;
  letter-spacing: 0.02em;
  line-height: 1;
  white-space: nowrap;
  transition: color 0.22s ease;
}
.apna-nav__item--active .apna-nav__label {
  background: linear-gradient(90deg, #8A2BE2, #c77dff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ══════════════════════════════════════
   FAB (Cart) — centre floating button
   ══════════════════════════════════════ */
.apna-nav__item--fab {
  flex: 1;
  /* No negative margin — FAB sits inside the nav height */
  padding-top: 0;
  padding-bottom: 0.2rem;
  gap: 0.25rem;
  /* Align to top of inner row so FAB appears to float */
  align-self: flex-start;
  margin-top: -1rem;
}

/* Outer spinning ring */
.apna-nav__fab-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  /* Size matches FAB + ring padding */
  width: clamp(52px, 13vw, 62px);
  height: clamp(52px, 13vw, 62px);
  flex-shrink: 0;
}
.apna-nav__fab-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: conic-gradient(from 0deg, #c77dff, #8A2BE2, #4B0082, #c77dff);
  animation: fab-ring-spin 4s linear infinite;
  opacity: 0.55;
}
@keyframes fab-ring-spin {
  to { transform: rotate(360deg); }
}
.apna-nav__item--fab:hover .apna-nav__fab-ring,
.apna-nav__item--fab.apna-nav__item--active .apna-nav__fab-ring {
  opacity: 1;
}

/* FAB button itself — sits inside the ring with a 4px gap */
.apna-nav__fab {
  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: linear-gradient(145deg, #a855f7 0%, #8A2BE2 45%, #4B0082 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 4px 18px rgba(138, 43, 226, 0.55),
    0 8px 28px rgba(75, 0, 130, 0.28),
    inset 0 1px 0 rgba(255,255,255,0.25);
  transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.22s ease;
  animation: fab-float 3.5s ease-in-out infinite;
}
@keyframes fab-float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-3px); }
}
.apna-nav__item--fab:hover .apna-nav__fab {
  transform: scale(1.08) translateY(-2px);
  animation: none;
}
.apna-nav__item--fab:active .apna-nav__fab {
  transform: scale(0.93);
  animation: none;
}
.apna-nav__item--fab.apna-nav__item--active .apna-nav__fab {
  background: linear-gradient(145deg, #c77dff 0%, #8A2BE2 50%, #3b0080 100%);
}

.apna-nav__fab-icon {
  width: clamp(20px, 5vw, 26px);
  height: clamp(20px, 5vw, 26px);
  color: #fff;
  filter: drop-shadow(0 1px 3px rgba(0,0,0,0.3));
}

/* Cart badge */
.apna-nav__fab-badge {
  position: absolute;
  top: 2px;
  right: 2px;
  min-width: 18px;
  height: 18px;
  padding: 0 4px;
  border-radius: 999px;
  background: linear-gradient(135deg, #ff6b6b, #ef4444);
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid rgba(255,248,255,0.95);
  box-shadow: 0 2px 6px rgba(239,68,68,0.5);
  animation: badge-pop 0.35s cubic-bezier(0.34,1.56,0.64,1) both;
  z-index: 2;
}
@keyframes badge-pop {
  from { transform: scale(0) rotate(-15deg); }
  to   { transform: scale(1) rotate(0deg); }
}

/* FAB label */
.apna-nav__label--fab {
  color: #b0b0c8;
}
.apna-nav__item--fab.apna-nav__item--active .apna-nav__label--fab {
  background: linear-gradient(90deg, #8A2BE2, #c77dff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── Push page content above the nav ── */
body {
  padding-bottom: calc(4.5rem + env(safe-area-inset-bottom, 0px));
}
</style>

<% } %>

<% if (typeof pageJS !== 'undefined' && pageJS) { %>
<script src="/js/main.js"></script>
<script src="/js/<%= pageJS %>"></script>
<% } %>

<script>
/* Sync cart badge from localStorage */
(function () {
  try {
    var cart = JSON.parse(localStorage.getItem('apnaMandi_cart') || '[]');
    var count = cart.reduce(function (s, i) { return s + (i.qty || 1); }, 0);
    var badge = document.getElementById('nav-cart-badge');
    if (badge && count > 0) {
      badge.textContent = count > 99 ? '99+' : count;
      badge.style.display = 'flex';
    }
  } catch (e) {}
})();
</script>
</body>
</html>
