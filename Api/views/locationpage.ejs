<%- include('./partials/header', {
  title: 'Select Location',
  pageCSS: 'locationpage.css'
}) %>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<div class="relative flex size-full min-h-screen flex-col">

  <!-- Header -->
  <header class="sticky top-0 z-[100] glass border-b border-[var(--border-light)]">
    <div class="flex items-center p-4 pb-3 gap-3">
      <button class="icon_button" onclick="history.back()" aria-label="Go back">
        <svg fill="none" height="22" stroke="currentColor" viewBox="0 0 24 24" width="22">
          <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
        </svg>
      </button>
      <h1 style="font-size:1.0625rem;font-weight:700;color:var(--text-primary);flex:1;text-align:center">Select Your Hub</h1>
      <div style="width:2.5rem"></div>
    </div>
  </header>

  <main style="padding:1rem;padding-bottom:7rem;display:flex;flex-direction:column;gap:1rem">

    <!-- Current location card -->
    <div id="current-loc-card" style="background:var(--primary-light);border:1.5px solid rgba(245,197,24,.35);border-radius:var(--radius-xl);padding:1rem;display:flex;align-items:center;justify-content:space-between;gap:0.75rem">
      <div style="display:flex;align-items:center;gap:0.75rem;flex:1;min-width:0">
        <div style="width:2.5rem;height:2.5rem;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div style="min-width:0">
          <p style="font-size:0.75rem;color:var(--text-secondary)">Selected Location</p>
          <p id="selected-loc-text" style="font-weight:700;font-size:0.9375rem;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
            Detecting…
          </p>
        </div>
      </div>
      <button id="use-gps-btn" class="button_secondary" style="font-size:0.8125rem;padding:0.45rem 0.875rem;flex-shrink:0;white-space:nowrap">
        📍 Use GPS
      </button>
    </div>

    <!-- Search box -->
    <div style="position:relative">
      <div class="search-container" style="margin-bottom:0">
        <span class="search-icon">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </span>
        <input type="search" id="hub-search" class="search-input"
               placeholder="Search city, area or landmark…" autocomplete="off"/>
        <div id="search-spinner" style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);display:none">
          <span class="spinner spinner-dark" style="width:1rem;height:1rem;border-width:1.5px"></span>
        </div>
      </div>

      <!-- Suggestions dropdown -->
      <div id="location-suggestions"
           style="position:absolute;top:calc(100% + 4px);left:0;right:0;background:#fff;border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);z-index:200;overflow:hidden;max-height:220px;overflow-y:auto;display:none">
      </div>
    </div>

    <!-- Map -->
    <div style="position:relative;border-radius:var(--radius-xl);overflow:hidden;box-shadow:var(--shadow-md);background:#f0f0f0">
      <div id="map" style="width:100%;height:320px;min-height:320px;z-index:1;background:#f0f0f0"></div>

      <!-- Map overlay hint -->
      <div id="map-hint" style="position:absolute;bottom:0.75rem;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.6);color:#fff;font-size:0.75rem;padding:0.35rem 0.875rem;border-radius:var(--radius-full);pointer-events:none;white-space:nowrap;z-index:10">
        Tap anywhere on map to select location
      </div>
    </div>

    <!-- Coordinates display -->
    <div id="coords-display" style="text-align:center;font-size:0.75rem;color:var(--text-muted);display:none">
      Lat: <span id="lat-val">—</span> · Lng: <span id="lng-val">—</span>
    </div>

    <p style="font-size:0.8125rem;color:var(--text-secondary);text-align:center;line-height:1.5">
      Pin your hub location on the map or search above.<br/>
      This helps us show you the nearest vendors.
    </p>

  </main>

  <!-- Confirm bar -->
  <div style="position:fixed;bottom:0;left:0;right:0;width:100%;background:rgba(255,255,255,0.95);backdrop-filter:blur(10px);padding:1rem;border-top:1px solid var(--border-light);z-index:50">
    <button id="confirm-btn" class="button_primary" style="width:100%;font-size:1rem;padding:0.875rem">
      Confirm Hub Location
    </button>
  </div>

</div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<%- include('./partials/footer', { showNav: false, pageJS: 'locationpage.js' }) %>
