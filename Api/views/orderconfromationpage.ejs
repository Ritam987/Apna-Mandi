<%- include('./partials/header', {
  title: 'Order Confirmation',
  pageCSS: 'orderconfromationpage.css',
  bodyClass: 'bg-[var(--background-color)]'
}) %>

<div class="relative flex size-full min-h-screen flex-col justify-between group/design-root overflow-x-hidden text-[var(--text-primary)] max-w-md mx-auto">
<header class="p-4">
<div class="flex items-center justify-between">
<button class="flex size-10 items-center justify-center rounded-full" onclick="history.back()">
<svg fill="currentColor" height="24px" viewBox="0 0 256 256" width="24px" xmlns="http://www.w3.org/2000/svg">
<path d="M224,128a8,8,0,0,1-8,8H59.31l58.35,58.34a8,8,0,0,1-11.32,11.32l-72-72a8,8,0,0,1,0-11.32l72-72a8,8,0,0,1,11.32,11.32L59.31,120H216A8,8,0,0,1,224,128Z"></path>
</svg>
</button>
<h1 class="flex-1 text-center text-xl font-bold">Order Confirmation</h1>
<div class="w-10"></div>
</div>
</header>
<main class="flex-grow px-4 pb-8 pt-4 text-center">
<div class="flex justify-center">
<div class="mb-6 flex size-24 items-center justify-center rounded-full bg-green-100 text-green-500 shadow-lg">
<svg fill="currentColor" height="48px" viewBox="0 0 256 256" width="48px" xmlns="http://www.w3.org/2000/svg">
<path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"></path>
</svg>
</div>
</div>
<h2 class="mb-2 text-2xl font-bold">Your order has been placed successfully!</h2>
<p class="mb-2 text-base text-[var(--text-secondary)]">Order ID: #1234567890</p>
<p class="text-base text-[var(--text-secondary)]">Estimated Delivery: 10:00 AM - 11:00 AM</p>
<div class="card my-6 text-left">
<h3 class="mb-4 text-lg font-bold">Quick Order Summary</h3>
<div class="space-y-3">
<div class="flex justify-between">
<div><p class="font-medium">Spices</p><p class="text-sm text-[var(--text-secondary)]">2 items</p></div>
<p>₹ 250</p>
</div>
<div class="flex justify-between">
<div><p class="font-medium">Vegetables</p><p class="text-sm text-[var(--text-secondary)]">1 item</p></div>
<p>₹ 150</p>
</div>
</div>
<hr class="my-4 border-gray-200"/>
<div class="space-y-2">
<div class="flex justify-between text-[var(--text-secondary)]"><p>Subtotal</p><p>₹ 400</p></div>
<div class="flex justify-between text-[var(--text-secondary)]"><p>Delivery Fee</p><p>₹ 50</p></div>
<div class="flex justify-between font-bold text-[var(--text-primary)]"><p>Total</p><p>₹ 450</p></div>
</div>
</div>
<div class="space-y-3">
<button onclick="trackOrder()" class="button_primary w-full transform transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]">Track Order</button>
<button onclick="continueShopping()" class="button_secondary w-full transform transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]">Continue Shopping</button>
</div>
</main>

<%- include('./partials/footer', { activePage: 'home', pageJS: 'orderconfromationpage.js' }) %>
