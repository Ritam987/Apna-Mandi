<%- include('./partials/header', {
  title: 'Account & Profile',
  pageCSS: 'accountorprofilepage.css',
  bodyClass: 'bg-[var(--bg-soft)]'
}) %>

<div class="relative flex size-full min-h-screen flex-col">
  <header class="sticky top-0 z-10 glass border-b border-[var(--border-light)] px-4 py-3">
    <div class="flex items-center justify-between">
      <button class="icon_button" onclick="history.back()" aria-label="Go back">
        <svg fill="none" height="22" stroke="currentColor" viewBox="0 0 24 24" width="22">
          <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
        </svg>
      </button>
      <h1 style="font-size:1.0625rem;font-weight:700;color:var(--text-primary)">Account &amp; Profile</h1>
      <div style="width:2.5rem"></div>
    </div>
  </header>

  <main style="padding:1rem;padding-bottom:6rem;display:flex;flex-direction:column;gap:1rem">

    <!-- Profile card -->
    <div class="card text-center animate-fade-in">
      <div class="profile-avatar">
        <svg fill="currentColor" height="40" viewBox="0 0 256 256" width="40" xmlns="http://www.w3.org/2000/svg">
          <path d="M230.92,212c-15.23-26.33-38.7-45.21-66.09-54.16a72,72,0,1,0-73.66,0C63.78,166.78,40.31,185.66,25.08,212a8,8,0,1,0,13.85,8c18.84-32.56,52.14-52,89.07-52s70.23,19.44,89.07,52a8,8,0,1,0,13.85-8ZM72,96a56,56,0,1,1,56,56A56.06,56.06,0,0,1,72,96Z"/>
        </svg>
        <div class="edit-overlay">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
      </div>
      <h2 id="user-name" style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">Guest User</h2>
      <p id="user-phone" style="color:var(--text-secondary);font-size:0.875rem;margin-top:0.2rem"></p>
      <button class="button_secondary" style="margin-top:0.875rem;font-size:0.875rem;padding:0.5rem 1.25rem"
              onclick="showToast('Profile editing coming soon')">Edit Profile</button>
    </div>

    <!-- Quick actions -->
    <div class="card animate-fade-in stagger-1">
      <h3 style="font-weight:700;font-size:0.9375rem;margin-bottom:0.875rem;color:var(--text-primary)">Quick Actions</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">
        <button id="btn-cart" class="quick-action-btn">
          <svg fill="currentColor" height="24" viewBox="0 0 256 256" width="24"><path d="M222.14,58.87A8,8,0,0,0,216,56H54.68L49.79,29.14A16,16,0,0,0,34.05,16H16a8,8,0,0,0,0,16h18L59.56,172.29a24,24,0,0,0,5.33,11.27,28,28,0,1,0,44.4,8.44h45.42A27.75,27.75,0,0,0,152,204a28,28,0,1,0,28-28H83.17a8,8,0,0,1-7.87-6.57L72.13,152h116a24,24,0,0,0,23.61-19.71l12.16-66.86A8,8,0,0,0,222.14,58.87Z"/></svg>
          My Cart
        </button>
        <button id="btn-orders" class="quick-action-btn">
          <svg fill="currentColor" height="24" viewBox="0 0 256 256" width="24"><path d="M232,56V208a8,8,0,0,1-11.58,7.15L192,200.94l-28.42,14.21a8,8,0,0,1-7.16,0L128,200.94,99.58,215.15a8,8,0,0,1-7.16,0L64,200.94,35.58,215.15A8,8,0,0,1,24,208V56A16,16,0,0,1,40,40H216A16,16,0,0,1,232,56Z"/></svg>
          My Orders
        </button>
        <button id="btn-wishlist" class="quick-action-btn">
          <svg fill="currentColor" height="24" viewBox="0 0 256 256" width="24"><path d="M224,115.55V208a16,16,0,0,1-16,16H168a16,16,0,0,1-16-16V168a8,8,0,0,0-8-8H112a8,8,0,0,0-8,8v40a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V115.55a16,16,0,0,1,5.17-11.78l80-75.48.11-.11a16,16,0,0,1,21.53,0,1.14,1.14,0,0,0,.11.11l80,75.48A16,16,0,0,1,224,115.55Z"/></svg>
          Wishlist
        </button>
        <button id="btn-offers" class="quick-action-btn">
          <svg fill="currentColor" height="24" viewBox="0 0 256 256" width="24"><path d="M176,172a12,12,0,1,1-12-12A12,12,0,0,1,176,172ZM92,96A12,12,0,1,0,80,84,12,12,0,0,0,92,96ZM224,48V208a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V48A16,16,0,0,1,48,32H208A16,16,0,0,1,224,48Z"/></svg>
          Offers
        </button>
      </div>
    </div>

    <!-- Settings -->
    <div class="card animate-fade-in stagger-2" style="padding:0">
      <h3 style="font-weight:700;font-size:0.9375rem;padding:1rem 1rem 0.5rem;color:var(--text-primary)">Account Settings</h3>
      <div id="btn-addresses" class="settings-item">
        <div class="settings-item-left">
          <div class="settings-item-icon">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <span style="font-size:0.9375rem;font-weight:500">Delivery Addresses</span>
        </div>
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </div>
      <div id="btn-payments" class="settings-item">
        <div class="settings-item-left">
          <div class="settings-item-icon">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          </div>
          <span style="font-size:0.9375rem;font-weight:500">Payment Methods</span>
        </div>
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </div>
      <div id="btn-notifications" class="settings-item">
        <div class="settings-item-left">
          <div class="settings-item-icon">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
          <span style="font-size:0.9375rem;font-weight:500">Notifications</span>
        </div>
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </div>
      <div id="btn-help" class="settings-item">
        <div class="settings-item-left">
          <div class="settings-item-icon">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <span style="font-size:0.9375rem;font-weight:500">Help &amp; Support</span>
        </div>
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </div>
    </div>

    <!-- Logout -->
    <button id="logout-btn" class="button_secondary animate-fade-in stagger-3"
            style="width:100%;color:var(--error);border-color:var(--error-light)">
      Logout
    </button>

  </main>
</div>

<%- include('./partials/footer', { activePage: 'profile', pageJS: 'accountorprofilepage.js' }) %>
