<%- include('./partials/header', {
  title: 'Log in or Sign up',
  pageCSS: 'loginorsignuppage.css',
  bodyClass: 'auth-page'
}) %>

<div class="auth-page-wrap">
  <!-- Floating orbs -->
  <div class="auth-orb auth-orb-1"></div>
  <div class="auth-orb auth-orb-2"></div>
  <div class="auth-orb auth-orb-3"></div>

  <!-- Glass card -->
  <div class="auth-card animate-scale-in">

    <!-- Step indicators -->
    <div class="step-indicator">
      <div class="step-dot active"></div>
      <div class="step-dot"></div>
      <div class="step-dot"></div>
    </div>

    <!-- Logo ring -->
    <div class="auth-logo-ring">
      <img alt="Apna Mandi"
           src="https://lh3.googleusercontent.com/aida-public/AB6AXuBpnVAlI69KX_q2P7gNYGhypM4kAYq23wT5T4N4BnjekImWCQET00fzkFSpmnmhqadgY2adS_oLJ_5ADJTm7VyZkqeeXiRORffEnRvYPcoeGED8i3iQ2tCFxR5tuZQU0CKNv8RrRowlWBgOquyyO2qIU42mgA6_Vc388dAowZSwYA9nhrBkiHTWLw4NSbSHL15PZjPAf-v45gPijzLucG97yD2cTD1gjin95hjF3SGxcxOa-ElnDUHpJ4F28Ck4_wkl2tYZ3g_Ondc"/>
    </div>

    <div style="text-align:center;margin-bottom:1.5rem">
      <h1 class="auth-title">Apna Mandi</h1>
      <p style="color:var(--text-secondary);margin-top:0.3rem;font-size:0.9rem">Wholesale Prices at Your Fingertips</p>
    </div>

    <!-- ── View 1: Mobile input ── -->
    <div id="mobile-input-view" class="auth-view">
      <h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary);margin-bottom:0.3rem;text-align:center">Login or Sign Up</h2>
      <p style="color:var(--text-secondary);margin-bottom:1.25rem;font-size:0.875rem;text-align:center">Enter your mobile number to continue</p>

      <div class="input-group" style="margin-bottom:0.5rem">
        <span class="input-icon">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </span>
        <input id="mobile-number" class="input" type="tel" placeholder="10-digit mobile number"
               inputmode="numeric" maxlength="10" autocomplete="tel"/>
      </div>
      <p id="mobile-error" class="error-message">Please enter a valid 10-digit mobile number</p>

      <button id="send-otp-btn" class="button_primary" style="width:100%;margin-top:1rem;font-size:1rem;padding:0.875rem">
        <span class="button-content"><span>Get OTP</span></span>
      </button>
    </div>

    <!-- ── View 2: OTP ── -->
    <div id="otp-view" class="hidden auth-view">
      <h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary);margin-bottom:0.3rem;text-align:center">Verify Number</h2>
      <p style="color:var(--text-secondary);margin-bottom:1.5rem;font-size:0.875rem;text-align:center">
        Code sent to <strong id="display-mobile-number" style="color:var(--primary)">+91 XXXXX XXXXX</strong>
      </p>

      <div style="display:flex;justify-content:center;gap:0.75rem;margin-bottom:1.25rem">
        <input class="otp-box" type="number" inputmode="numeric" maxlength="1" aria-label="OTP digit 1"/>
        <input class="otp-box" type="number" inputmode="numeric" maxlength="1" aria-label="OTP digit 2"/>
        <input class="otp-box" type="number" inputmode="numeric" maxlength="1" aria-label="OTP digit 3"/>
        <input class="otp-box" type="number" inputmode="numeric" maxlength="1" aria-label="OTP digit 4"/>
      </div>

      <button id="verify-otp-btn" class="button_primary" style="width:100%;font-size:1rem;padding:0.875rem" disabled>
        Verify
      </button>
      <p style="margin-top:1rem;font-size:0.875rem;color:var(--text-secondary);text-align:center">
        Didn't receive it?
        <button id="resend-otp-btn" style="font-weight:600;color:var(--primary);margin-left:0.25rem;background:none;border:none;cursor:pointer">Resend OTP</button>
      </p>
    </div>

    <!-- ── View 3: User data ── -->
    <div id="user-data-view" class="hidden auth-view" style="text-align:left">
      <h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary);margin-bottom:0.3rem;text-align:center">Complete Profile</h2>
      <p style="color:var(--text-secondary);margin-bottom:1.25rem;font-size:0.875rem;text-align:center">Just a few details to get started</p>

      <form id="user-data-form" style="display:flex;flex-direction:column;gap:0.875rem">
        <div class="form-field">
          <label class="form-label" for="fullName">Full Name *</label>
          <div class="input-group">
            <span class="input-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </span>
            <input class="input" id="fullName" name="fullName" type="text" placeholder="Your full name" required/>
          </div>
        </div>
        <div class="form-field">
          <label class="form-label" for="age">Age *</label>
          <div class="input-group">
            <span class="input-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </span>
            <input class="input" id="age" name="age" type="number" placeholder="Your age" min="18" max="100" required/>
          </div>
        </div>
        <div class="form-field">
          <label class="form-label">Gender *</label>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
            <label class="gender-option"><input type="radio" name="gender" value="male" required/>👨 Male</label>
            <label class="gender-option"><input type="radio" name="gender" value="female"/>👩 Female</label>
            <label class="gender-option"><input type="radio" name="gender" value="other"/>🧑 Other</label>
          </div>
        </div>
        <div class="form-field">
          <label class="form-label" for="email">Email (optional)</label>
          <div class="input-group">
            <span class="input-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </span>
            <input class="input" id="email" name="email" type="email" placeholder="your@email.com"/>
          </div>
        </div>
        <div class="form-field">
          <label class="form-label" for="address">Address *</label>
          <textarea class="input" id="address" name="address" rows="2"
                    placeholder="Your delivery address" required
                    style="border-radius:var(--radius-md);resize:none;padding-top:0.75rem"></textarea>
        </div>
        <button type="submit" class="button_primary" style="width:100%;font-size:1rem;padding:0.875rem;margin-top:0.25rem">
          Create Profile
        </button>
      </form>
    </div>

  </div><!-- /auth-card -->

  <footer class="auth-footer">
    <p>By continuing, you agree to our
      <a href="#">Terms</a> &amp;
      <a href="#">Privacy Policy</a>
    </p>
  </footer>
</div>

<%- include('./partials/footer', { showNav: false, pageJS: 'loginorsignuppage.js' }) %>
