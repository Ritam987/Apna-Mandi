<%- include('./partials/header', {
  title: 'Special Offers',
  inlineStyles: `
    :root {
        --primary-color: #eeee06;
        --background-color: #fefefe;
        --text-primary: #1a1a1a;
        --text-secondary: #4d4d4d;
        --accent-color: #f5f5f5;
    }
    body {
        font-family: 'Spline Sans', sans-serif;
        background-color: var(--background-color);
        color: var(--text-primary);
        min-height: max(884px, 100dvh);
        scroll-behavior: smooth;
    }
    .card { @apply bg-white rounded-2xl shadow-sm transition-transform hover:shadow-md active:scale-[0.98]; }
    .button_primary { @apply bg-[var(--primary-color)] text-[var(--text-primary)] rounded-full px-8 py-4 font-bold text-xl hover:bg-yellow-400 transition-all active:scale-[0.98] shadow-sm; }
    .button_secondary { @apply bg-[var(--accent-color)] text-[var(--text-primary)] rounded-full px-6 py-3 hover:bg-gray-200 text-lg font-medium transition-all active:scale-[0.98]; }
    .section_title { @apply text-3xl font-bold text-[var(--text-primary)] mb-6 px-5; }
    .icon_button { @apply rounded-full p-3 hover:bg-gray-100; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .fade-in { animation: fadeInUp 0.5s ease-out forwards; }
  `
}) %>

