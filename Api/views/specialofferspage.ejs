<%- include('./partials/header', {
  title: 'Special Offers',
  pageCSS: 'specialofferspage.css',
  bodyClass: ''
}) %>

<div class="so-root">

  <!-- Header -->
  <header class="so-header">
    <button class="icon_button" onclick="history.back()" aria-label="Go back">
      <svg fill="none" height="22" stroke="currentColor" viewBox="0 0 24 24" width="22">
        <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
      </svg>
    </button>
    <h1 style="font-size:1.0625rem;font-weight:700;color:var(--text-primary)">Special Offers</h1>
    <div style="width:2.5rem"></div>
  </header>

  <main class="so-main">

    <!-- Hero Banner -->
    <div class="so-hero">
      <div class="so-hero__content">
        <span class="so-hero__tag">🔥 Limited Time</span>
        <h2 class="so-hero__title">Mega Deals</h2>
        <p class="so-hero__sub">Fresh produce at wholesale prices</p>
        <div class="so-hero__timer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
          </svg>
          <span>Ends in: </span>
          <span id="so-countdown" class="so-hero__countdown">02:00:00</span>
        </div>
      </div>
      <div class="so-hero__img-wrap">
        <img src="https://images.unsplash.com/photo-1540420773420-3366772f4999?w=300&q=80" alt="Fresh Produce" class="so-hero__img"/>
      </div>
    </div>

    <!-- Filter chips -->
    <div class="so-filters hide-scrollbar">
      <button class="chip active" data-filter="all">All</button>
      <button class="chip" data-filter="flash">⚡ Flash Sale</button>
      <button class="chip" data-filter="bulk">📦 Bulk Orders</button>
      <button class="chip" data-filter="seasonal">🌿 Seasonal</button>
      <button class="chip" data-filter="surplus">♻️ Surplus</button>
    </div>

    <!-- Featured Deals -->
    <section class="so-section" id="so-featured-section">
      <div class="so-section__head">
        <h2 class="so-section__title">⚡ Flash Sale</h2>
        <a href="/pages/searchfeed" class="so-section__link">See all →</a>
      </div>
      <div class="so-hscroll hide-scrollbar" id="so-featured-list">
        <!-- Rendered by JS -->
      </div>
    </section>

    <!-- Bulk Orders -->
    <section class="so-section" id="so-bulk-section">
      <div class="so-section__head">
        <h2 class="so-section__title">📦 Bulk Orders</h2>
        <span style="font-size:0.8rem;color:var(--text-secondary)">Wholesale prices</span>
      </div>
      <div id="so-bulk-list" style="display:flex;flex-direction:column;gap:0.875rem">
        <!-- Rendered by JS -->
      </div>
    </section>

    <!-- Seasonal Picks -->
    <section class="so-section" id="so-seasonal-section">
      <div class="so-section__head">
        <h2 class="so-section__title">🌿 Seasonal Picks</h2>
        <span style="font-size:0.8rem;color:var(--text-secondary)">Fresh this season</span>
      </div>
      <div id="so-seasonal-list" class="so-seasonal-grid">
        <!-- Rendered by JS -->
      </div>
    </section>

    <!-- Surplus -->
    <section class="so-section" id="so-surplus-section">
      <div class="so-section__head">
        <h2 class="so-section__title">♻️ Surplus Deals</h2>
        <span style="font-size:0.8rem;color:var(--text-secondary)">Limited stock</span>
      </div>
      <div id="so-surplus-list" class="so-seasonal-grid">
        <!-- Rendered by JS -->
      </div>
    </section>

  </main>
</div>

<%- include('./partials/footer', { activePage: 'surplus', pageJS: 'specialofferspage.js' }) %>
