<%- include('./partials/header', {
  title: 'Search Feed',
  pageCSS: 'searchfeedpage.css',
  bodyClass: ''
}) %>

<div class="sf-root">

  <!-- Sticky Header -->
  <header class="sf-header">
    <div class="sf-header__row">
      <button class="icon_button" onclick="history.back()" aria-label="Go back">
        <svg fill="none" height="22" stroke="currentColor" viewBox="0 0 24 24" width="22">
          <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
        </svg>
      </button>
      <div class="sf-search-wrap">
        <span class="sf-search-icon">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </span>
        <input id="search-input" type="search" placeholder="Search products…" autocomplete="off"/>
      </div>
      <button class="icon_button" aria-label="Filter" onclick="showToast('Filters coming soon')">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
        </svg>
      </button>
    </div>

    <!-- Category chips -->
    <div class="sf-chips hide-scrollbar">
      <button class="chip active" data-category="all">All</button>
      <button class="chip" data-category="vegetables">🥦 Vegetables</button>
      <button class="chip" data-category="fruits">🍎 Fruits</button>
      <button class="chip" data-category="spices">🌶 Spices</button>
      <button class="chip" data-category="dairy">🥛 Dairy</button>
      <button class="chip" data-category="grains">🌾 Grains</button>
      <button class="chip" data-category="herbs">🌿 Herbs</button>
      <button class="chip" data-category="dry-fruits">🥜 Dry Fruits</button>
    </div>

    <!-- Sort row -->
    <div class="sf-sort-row">
      <p id="result-count" class="sf-result-count"></p>
      <div class="sf-sort-chips hide-scrollbar">
        <button class="chip" data-sort="price-asc">Price ↑</button>
        <button class="chip" data-sort="price-desc">Price ↓</button>
        <button class="chip" data-sort="name">A–Z</button>
        <button class="chip" data-sort="discount">Discount</button>
      </div>
    </div>
  </header>

  <main class="sf-main">
    <div id="product-grid" class="sf-grid"></div>
  </main>

</div>

<%- include('./partials/footer', { activePage: 'categories', pageJS: 'searchfeedpage.js' }) %>
