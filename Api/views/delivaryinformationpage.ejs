<%- include('./partials/header', {
  title: 'Delivery Information',
  pageCSS: 'delivaryinformationpage.css',
  bodyClass: ''
}) %>

<div class="di-root">

  <!-- Sticky Header -->
  <header class="di-header">
    <button class="icon_button" onclick="history.back()" aria-label="Go back">
      <svg fill="none" height="22" stroke="currentColor" viewBox="0 0 24 24" width="22">
        <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
      </svg>
    </button>
    <h1 style="font-size:1.0625rem;font-weight:700;color:var(--text-primary)">Delivery Information</h1>
    <div style="width:2.5rem"></div>
  </header>

  <main class="di-main">

    <!-- Current Location -->
    <section class="di-section">
      <h2 class="di-section__title">Current Location</h2>
      <div class="di-loc-card">
        <div class="di-loc-icon">
          <svg fill="none" width="22" height="22" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p style="font-weight:600;color:var(--text-primary)" id="di-city">Kochi, Kerala</p>
          <p style="font-size:0.8125rem;color:var(--text-secondary)">Default Hub</p>
        </div>
      </div>
    </section>

    <!-- Saved Addresses -->
    <section class="di-section">
      <h2 class="di-section__title">Saved Addresses</h2>
      <div id="address-list" style="display:flex;flex-direction:column;gap:0.75rem"></div>
      <button id="add-address-btn" class="button_secondary di-add-btn">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        Add New Address
      </button>
    </section>

    <!-- Delivery Slot -->
    <section class="di-section">
      <h2 class="di-section__title">Delivery Slot</h2>
      <div style="display:flex;flex-direction:column;gap:0.75rem">
        <label class="slot-option">
          <input checked name="delivery_slot" type="radio" style="accent-color:var(--primary)"/>
          <div>
            <span style="font-weight:600;color:var(--text-primary)">Today, 6:00 PM – 7:00 PM</span>
            <p style="font-size:0.75rem;color:var(--text-secondary);margin-top:1px">Express delivery</p>
          </div>
        </label>
        <label class="slot-option">
          <input name="delivery_slot" type="radio" style="accent-color:var(--primary)"/>
          <div>
            <span style="font-weight:600;color:var(--text-primary)">Tomorrow, 10:00 AM – 11:00 AM</span>
            <p style="font-size:0.75rem;color:var(--text-secondary);margin-top:1px">Standard delivery</p>
          </div>
        </label>
        <label class="slot-option">
          <input name="delivery_slot" type="radio" style="accent-color:var(--primary)"/>
          <div>
            <span style="font-weight:600;color:var(--text-primary)">Tomorrow, 4:00 PM – 5:00 PM</span>
            <p style="font-size:0.75rem;color:var(--text-secondary);margin-top:1px">Evening delivery</p>
          </div>
        </label>
      </div>
    </section>

    <!-- Delivery Instructions -->
    <section class="di-section">
      <h2 class="di-section__title">Delivery Instructions</h2>
      <textarea id="delivery-instructions" class="input" rows="3"
                placeholder="e.g. Leave package at the front door"
                style="resize:none;margin-top:0.5rem"></textarea>
    </section>

  </main>

  <!-- Continue button -->
  <div class="di-footer">
    <button id="continue-btn" class="button_primary" style="width:100%;font-size:1rem;padding:0.875rem"
            onclick="continueToPayment()">
      Continue to Payment
    </button>
  </div>

</div>

<!-- Add Address Modal -->
<div id="add-address-modal" class="add-address-modal">
  <div class="add-address-sheet">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
      <h3 style="font-size:1.0625rem;font-weight:700;color:var(--text-primary)">Add New Address</h3>
      <button id="close-address-modal" class="icon_button" aria-label="Close">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <form id="add-address-form" style="display:flex;flex-direction:column;gap:0.875rem">
      <div>
        <label style="font-size:0.875rem;font-weight:500;color:var(--text-primary);display:block;margin-bottom:0.35rem">Label (Home / Office)</label>
        <input class="input" name="label" type="text" placeholder="e.g. Home" required/>
      </div>
      <div>
        <label style="font-size:0.875rem;font-weight:500;color:var(--text-primary);display:block;margin-bottom:0.35rem">Full Address</label>
        <textarea class="input" name="address" rows="3" placeholder="Street, City, State, PIN" required style="resize:none"></textarea>
      </div>
      <button type="submit" class="button_primary" style="width:100%">Save Address</button>
    </form>
  </div>
</div>
<div id="modal-overlay" class="modal-overlay"></div>

<%- include('./partials/footer', { showNav: false, pageJS: 'delivaryinformationpage.js' }) %>
