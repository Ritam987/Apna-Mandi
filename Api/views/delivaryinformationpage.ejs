<%- include('./partials/header', {
  title: 'Delivery Information',
  pageCSS: 'delivaryinformationpage.css',
  bodyClass: 'bg-[var(--background-color)]'
}) %>

<div class="relative flex min-h-screen flex-col justify-between max-w-md mx-auto w-full">
<div class="flex-grow w-full">
<header class="sticky top-0 z-10 flex items-center justify-between bg-white/80 p-4 pb-3 backdrop-blur-sm">
<button class="flex size-10 items-center justify-center rounded-full text-[var(--text-primary)] hover:bg-gray-100" onclick="history.back()">
<svg fill="currentColor" height="24" viewBox="0 0 256 256" width="24" xmlns="http://www.w3.org/2000/svg">
<path d="M224,128a8,8,0,0,1-8,8H59.31l58.35,58.34a8,8,0,0,1-11.32,11.32l-72-72a8,8,0,0,1,0-11.32l72-72a8,8,0,0,1,11.32,11.32L59.31,120H216A8,8,0,0,1,224,128Z"></path>
</svg>
</button>
<h1 class="text-xl font-bold text-[var(--text-primary)]">Delivery Information</h1>
<div class="size-10"></div>
</header>
<main class="px-4 pb-28">
<section class="mt-4">
<h2 class="text-lg font-semibold text-[var(--text-primary)]">Current Location</h2>
<div class="mt-2 flex items-center gap-4 rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
<div class="flex size-12 shrink-0 items-center justify-center rounded-full bg-gray-100 text-[var(--text-primary)]">
<svg fill="currentColor" height="24" viewBox="0 0 256 256" width="24" xmlns="http://www.w3.org/2000/svg">
<path d="M128,64a40,40,0,1,0,40,40A40,40,0,0,0,128,64Zm0,64a24,24,0,1,1,24-24A24,24,0,0,1,128,128Zm0-112a88.1,88.1,0,0,0-88,88c0,31.4,14.51,64.68,42,96.25a254.19,254.19,0,0,0,41.45,38.3,8,8,0,0,0,9.18,0A254.19,254.19,0,0,0,174,200.25c27.45-31.57,42-64.85,42-96.25A88.1,88.1,0,0,0,128,16Zm0,206c-16.53-13-72-60.75-72-118a72,72,0,0,1,144,0C200,161.23,144.53,209,128,222Z"></path>
</svg>
</div>
<div>
<p class="font-medium text-[var(--text-primary)]">Kochi, Kerala</p>
<p class="text-sm text-[var(--text-secondary)]">Default Hub</p>
</div>
</div>
</section>
<section class="mt-6">
<h2 class="text-lg font-semibold text-[var(--text-primary)]">Saved Addresses</h2>
<div class="mt-2 space-y-3">
<div class="group flex cursor-pointer items-center justify-between gap-4 rounded-xl border-2 border-transparent bg-white p-4 shadow-sm transition-all hover:border-[var(--primary-color)]">
<div class="flex items-center gap-4">
<div class="flex size-12 shrink-0 items-center justify-center rounded-full bg-gray-100 text-[var(--text-primary)]">
<svg fill="currentColor" height="24" viewBox="0 0 256 256" width="24" xmlns="http://www.w3.org/2000/svg">
<path d="M218.83,103.77l-80-75.48a1.14,1.14,0,0,1-.11-.11,16,16,0,0,0-21.53,0l-.11.11L37.17,103.77A16,16,0,0,0,32,115.55V208a16,16,0,0,0,16,16H96a16,16,0,0,0,16-16V160h32v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V115.55A16,16,0,0,0,218.83,103.77ZM208,208H160V160a16,16,0,0,0-16-16H112a16,16,0,0,0-16,16v48H48V115.55l.11-.1L128,40l79.9,75.43.11.1Z"></path>
</svg>
</div>
<div>
<p class="font-medium text-[var(--text-primary)]">123, MG Road, Kochi</p>
<p class="text-sm text-[var(--text-secondary)]">Home</p>
</div>
</div>
</div>
</div>
<button onclick="showAddAddressForm()" class="button_secondary mt-4 w-full text-center flex items-center justify-center gap-2 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200">
<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
</svg>
Add New Address
</button>
</section>
<section class="mt-6">
<h2 class="text-lg font-semibold text-[var(--text-primary)]">Delivery Slot</h2>
<div class="mt-2 space-y-3">
<label class="flex cursor-pointer items-center gap-4 rounded-xl border p-4 transition-all duration-200 hover:border-[var(--accent-color)] has-[:checked]:border-[var(--accent-color)] has-[:checked]:bg-[var(--primary-color)]">
<input checked="" class="h-5 w-5 border-2 border-gray-300 text-[var(--text-primary)] focus:ring-0" name="delivery_slot" type="radio"/>
<span class="font-medium text-[var(--text-primary)]">Today, 6:00 PM - 7:00 PM</span>
</label>
<label class="flex cursor-pointer items-center gap-4 rounded-xl border p-4 has-[:checked]:border-[var(--accent-color)] has-[:checked]:bg-[var(--primary-color)]">
<input class="h-5 w-5 border-2 border-gray-300 text-[var(--text-primary)] focus:ring-0" name="delivery_slot" type="radio"/>
<span class="font-medium text-[var(--text-primary)]">Tomorrow, 10:00 AM - 11:00 AM</span>
</label>
</div>
</section>
<section class="mt-6">
<h2 class="text-lg font-semibold text-[var(--text-primary)]">Delivery Instructions</h2>
<textarea class="input mt-2 w-full min-h-[100px] resize-y" placeholder="e.g. Leave package at the front door"></textarea>
</section>
</main>
</div>
<footer class="fixed bottom-0 left-1/2 -translate-x-1/2 z-10 border-t border-gray-200 bg-white/80 p-4 backdrop-blur-sm w-full max-w-md">
<button onclick="continueToPayment()" class="button_primary w-full text-center text-lg font-bold transform transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]">Continue to Payment</button>
</footer>
</div>

<%- include('./partials/footer', { showNav: false, pageJS: 'delivaryinformationpage.js' }) %>
