<%- include('./partials/header', {
  title: 'Checkout',
  pageCSS: 'checkoutpage.css',
  bodyClass: 'bg-[var(--bg-soft)]'
}) %>

<div class="page-wrapper">
  <!-- Header -->
  <header class="flex items-center justify-between p-4 sticky top-0 z-10 glass border-b border-[var(--border-light)]">
    <button class="icon_button" onclick="history.back()" aria-label="Go back">
      <svg fill="none" height="22" stroke="currentColor" viewBox="0 0 24 24" width="22">
        <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
      </svg>
    </button>
    <h1 style="font-size:1.0625rem;font-weight:700;color:var(--text-primary)">Checkout</h1>
    <div style="width:2.5rem"></div>
  </header>

  <main style="padding:1rem;padding-bottom:7rem">

    <!-- Order Summary -->
    <div class="checkout-section stagger-1">
      <h2 style="font-weight:700;font-size:1rem;margin-bottom:0.875rem;color:var(--text-primary)">Order Summary</h2>
      <div id="order-items"></div>
      <div style="margin-top:0.875rem;padding-top:0.875rem;border-top:1px solid var(--border-light)">
        <div class="price-row"><span style="color:var(--text-secondary)">Subtotal</span><span id="subtotal-val" style="font-weight:600">—</span></div>
        <div class="price-row"><span style="color:var(--text-secondary)">Delivery</span><span id="delivery-val" style="font-weight:600;color:var(--success)">Free</span></div>
        <div class="price-row"><span style="color:var(--text-secondary)">Discount</span><span id="discount-val" style="font-weight:600;color:var(--success)">—</span></div>
        <div class="price-row total"><span>Total</span><span id="total-val">—</span></div>
      </div>
    </div>

    <!-- Coupon -->
    <div class="checkout-section stagger-2">
      <h2 style="font-weight:700;font-size:1rem;margin-bottom:0.875rem;color:var(--text-primary)">Coupon Code</h2>
      <div class="coupon-input-wrap">
        <input id="coupon-input" class="input" placeholder="Enter coupon code" style="border-radius:var(--radius-full)"/>
        <button id="apply-coupon" class="coupon-apply-btn">Apply</button>
      </div>
      <p id="coupon-msg" style="font-size:0.8125rem;margin-top:0.4rem"></p>
      <p style="font-size:0.75rem;color:var(--text-muted);margin-top:0.35rem">Try: APNA10 · MANDI20 · FRESH50</p>
    </div>

    <!-- Delivery Address -->
    <div class="checkout-section stagger-3">
      <h2 style="font-weight:700;font-size:1rem;margin-bottom:0.875rem;color:var(--text-primary)">Delivery Address</h2>
      <div id="delivery-address-display" style="background:var(--bg-soft);border-radius:var(--radius-lg);padding:0.875rem;font-size:0.875rem;color:var(--text-secondary)">
        Loading address…
      </div>
    </div>

    <!-- Payment Methods -->
    <div class="checkout-section stagger-4">
      <h2 style="font-weight:700;font-size:1rem;margin-bottom:0.875rem;color:var(--text-primary)">Payment Method</h2>

      <label class="payment-option">
        <div class="payment-option-icon">
          <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <div style="flex:1">
          <p style="font-weight:600;font-size:0.9375rem">UPI</p>
          <p style="font-size:0.8rem;color:var(--text-secondary)">Pay via any UPI app</p>
        </div>
        <input type="radio" name="payment" value="upi" style="accent-color:var(--primary)"/>
      </label>

      <label class="payment-option">
        <div class="payment-option-icon">
          <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
        </div>
        <div style="flex:1">
          <p style="font-weight:600;font-size:0.9375rem">Card</p>
          <p style="font-size:0.8rem;color:var(--text-secondary)">Credit / Debit card</p>
        </div>
        <input type="radio" name="payment" value="card" style="accent-color:var(--primary)"/>
      </label>

      <label class="payment-option">
        <div class="payment-option-icon">
          <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <div style="flex:1">
          <p style="font-weight:600;font-size:0.9375rem">Cash on Delivery</p>
          <p style="font-size:0.8rem;color:var(--text-secondary)">Pay when delivered</p>
        </div>
        <input type="radio" name="payment" value="cod" style="accent-color:var(--primary)"/>
      </label>
    </div>

  </main>

  <!-- Place Order bar -->
  <div style="position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:rgba(255,255,255,0.95);backdrop-filter:blur(10px);padding:1rem;border-top:1px solid var(--border-light);z-index:20">
    <button id="place-order-btn" class="button_primary" style="width:100%;font-size:1rem;padding:0.9rem">
      Place Order
    </button>
    <p style="text-align:center;font-size:0.75rem;color:var(--text-muted);margin-top:0.5rem">
      By placing order you agree to our <a href="#" style="color:var(--text-primary);font-weight:500">Terms & Conditions</a>
    </p>
  </div>
</div>

<script>
// Load delivery address display
document.addEventListener('DOMContentLoaded', () => {
  try {
    const info = JSON.parse(localStorage.getItem('deliveryInfo') || '{}');
    const el = document.getElementById('delivery-address-display');
    if (el && info.address) {
      el.innerHTML = `<p style="font-weight:600;font-size:0.875rem;color:var(--text-primary)">${info.address.label || 'Address'}</p>
                      <p style="margin-top:0.2rem">${info.address.address || ''}</p>
                      <p style="margin-top:0.2rem;color:var(--primary-dark);font-weight:500">${info.slot || ''}</p>`;
    }
  } catch {}
});
</script>

<%- include('./partials/footer', { showNav: false, pageJS: 'checkoutpage.js' }) %>
