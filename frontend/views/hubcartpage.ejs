<%- include('./partials/header', {
  title: 'Hub Cart',
  pageCSS: 'hubcartpage.css',
  bodyClass: ''
}) %>

<div class="relative flex size-full min-h-screen flex-col">
  <!-- Header -->
  <header class="flex items-center justify-between p-4 sticky top-0 z-10 glass border-b border-[var(--border-light)]">
    <button class="icon_button" onclick="history.back()" aria-label="Go back">
      <svg fill="none" height="22" stroke="currentColor" viewBox="0 0 24 24" width="22">
        <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
      </svg>
    </button>
    <h1 style="font-size:1.125rem;font-weight:700;color:var(--text-primary)">Hub Cart</h1>
    <div style="width:2.5rem"></div>
  </header>

  <main style="padding:1rem;padding-bottom:14rem;display:flex;flex-direction:column;gap:0.875rem" id="cart-items-container">
    <!-- Rendered by JS -->
  </main>

  <!-- Summary bar -->
  <div id="cart-summary-bar" class="cart-summary-bar" style="display:none"></div>
</div>

<%- include('./partials/footer', { activePage: 'cart', pageJS: 'hubcartpage.js' }) %>
